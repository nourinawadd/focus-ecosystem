MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Anchor
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_EXPIRES_IN=1h
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
PORT=5000
# AI insights — primary provider: any OpenAI-compatible endpoint (GitHub Models
# by default; LLM_API_KEY is a GitHub fine-grained PAT with Models: read).
# Leave LLM_API_KEY unset to use Gemini only.
LLM_API_KEY=github_pat_your-token
LLM_BASE_URL=https://models.github.ai/inference
LLM_MODEL=openai/gpt-4.1-mini
# Gemini — automatic fallback when the primary provider fails or is rate-limited
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Email verification (codes via Brevo). Leave REQUIRE_EMAIL_VERIFICATION unset
# locally — register then behaves classically (no code, instant tokens).
REQUIRE_EMAIL_VERIFICATION=true
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER=anchorr26@gmail.com
GOOGLE_WEB_CLIENT_ID=your-google-web-oauth-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-oauth-client-id.apps.googleusercontent.com
APPLE_BUNDLE_ID=dev.gradproject.anchor
