# MongoDB connection string (Atlas SRV or local mongodb://...)
MONGO_URI=

# JWT signing secret. Required, must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# JWT refresh-token secret. Required. Generate the same way as JWT_SECRET.
JWT_REFRESH_SECRET=

# Comma-separated list of allowed CORS origins. Required.
# Example: http://localhost:8081,http://localhost:19006
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Access-token lifetime. Optional, defaults to 1h. Keep this short — refresh
# tokens (30d, rotated) handle long-lived sessions. Examples: 15m, 1h, 2h
JWT_EXPIRES_IN=1h

# Optional. Defaults to 5000.
PORT=5000

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
