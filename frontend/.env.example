# Base URL for the backend API. Must include /api suffix.
# - Android emulator: http://10.0.2.2:5000/api  (also the fallback if this var is unset)
# - iOS simulator:    http://localhost:5000/api
# - Expo Go on a physical phone: http://<your-PC-LAN-IPv4>:5000/api  (run `ipconfig`)
# - Web preview:      http://localhost:5000/api
#
# Note: EXPO_PUBLIC_* vars are inlined at bundle time. After editing, restart with
# `npx expo start -c` to clear the bundler cache.
EXPO_PUBLIC_API_URL=
